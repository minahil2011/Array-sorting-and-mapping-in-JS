<!DOCTYPE html>
<html>
    <head>
        <title>
            Evaluate the expression
        </title>
    </head>
    <body>
        <h1 style="color:aqua;">
            EVALUATING THE JS EXPRESSION
        </h1>
        <button onclick="myFunction()">CLICK ME!</button>
        <p id="result"></p>
        <script>
            function myFunction(){
                var x = 15;
                var y = 3;
            var a = eval("x / y") + "<br>";
            var b = eval("34 + 67") + "<br>";
            var c = eval("y - x") + "<br>";
            
            var res = a + b + c;

            document.getElementById("result").innerHTML = res;
            }
        </script>
    </body>
</html>
